<Window x:Class="TestSyncManager.RegisterTeacherDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#1056;&#1077;&#1075;&#1080;&#1089;&#1090;&#1088;&#1072;&#1094;&#1080;&#1103;"
        SizeToContent="Height" Width="400"
        MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,20">

            
            <Border Background="{StaticResource PrimaryBrush}" Width="48" Height="48" CornerRadius="24"
                    HorizontalAlignment="Center" Margin="0,0,0,12">
                <TextBlock Text="&#128100;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="&#1053;&#1086;&#1074;&#1099;&#1081; &#1087;&#1088;&#1077;&#1087;&#1086;&#1076;&#1072;&#1074;&#1072;&#1090;&#1077;&#1083;&#1100;"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="&#1047;&#1072;&#1087;&#1086;&#1083;&#1085;&#1080;&#1090;&#1077; &#1076;&#1072;&#1085;&#1085;&#1099;&#1077; &#1076;&#1083;&#1103; &#1074;&#1093;&#1086;&#1076;&#1072; &#1074; &#1089;&#1080;&#1089;&#1090;&#1077;&#1084;&#1091;"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            
            <Border x:Name="ErrorBorder" Background="#FFF0F0" CornerRadius="6" Padding="10,8" Margin="0,0,0,12"
                    Visibility="Collapsed" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1">
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}" FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            
            <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="EmailBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            
            <TextBlock Text="&#1060;&#1048;&#1054;" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

            
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="&#1055;&#1072;&#1088;&#1086;&#1083;&#1100;" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Grid.Column="0" Grid.Row="1"
                             FontSize="13" Padding="8,7"/>

                <TextBlock Grid.Column="2" Grid.Row="0"
                           Text="&#1055;&#1086;&#1074;&#1090;&#1086;&#1088;&#1080;&#1090;&#1077;" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Grid.Column="2" Grid.Row="1"
                             FontSize="13" Padding="8,7"/>
            </Grid>

            
            <Button Content="&#1047;&#1072;&#1088;&#1077;&#1075;&#1080;&#1089;&#1090;&#1088;&#1080;&#1088;&#1086;&#1074;&#1072;&#1090;&#1100;"
                    Style="{StaticResource PrimaryButton}"
                    Click="RegisterButton_Click"
                    HorizontalAlignment="Stretch"
                    Padding="16,10" Margin="0,0,0,8"/>

            <Button Content="&#1054;&#1090;&#1084;&#1077;&#1085;&#1072;"
                    Click="CancelButton_Click"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    FontSize="13" Cursor="Hand"
                    HorizontalAlignment="Center" Padding="16,6"/>
        </StackPanel>
    </ScrollViewer>
</Window>
